{
  "expo": {
    "name": "ResetPulse",
    "slug": "resetPulse",
    "version": "2.1.6",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F5F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.irimwebforge.resetpulse",
      "buildNumber": "28",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4A5568",
          "sounds": [
            "./assets/sounds/bell_short.wav",
            "./assets/sounds/634089__aj_heels__timercomplete01.wav",
            "./assets/sounds/815533__mihacappy__bell01.wav",
            "./assets/sounds/135873__crz1990__vintage-microwave-timer-bell-ring-26-november-2011-113900-pm.wav",
            "./assets/sounds/609725__theplax__microwave-ping.wav",
            "./assets/sounds/149506__dland__kitchen-timer-done.wav",
            "./assets/sounds/204103__maphill__kitchen-timer.wav",
            "./assets/sounds/490326__knufds__bell-egg-timer.wav",
            "./assets/sounds/564623__azumarill__toaster-oven-or-liftelevator-bell.wav",
            "./assets/sounds/615949__julesv4__ding-effect.wav"
          ]
        }
      ],
      "expo-localization",
      "expo-asset",
      "expo-audio"
    ],
    "notification": {
      "icon": "./assets/icon.png",
      "color": "#4A5568",
      "androidMode": "default",
      "androidCollapsedTitle": "ResetPulse"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E07B4F"
      },
      "package": "com.irimwebforge.resetpulse",
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "f98f80b8-4a15-4ece-afa5-5311174f67b8"
      },
      "revenueCat": {
        "iosKey": "appl_NJoSzWzcoJXLiNDMTGKJShISApt",
        "androidKey": "goog_URjPIqpNSxbyogfdststoCOmQRg"
      }
    }
  }
}

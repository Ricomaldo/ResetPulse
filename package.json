{
  "name": "resetpulse",
  "version": "2.1.6",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:critical": "jest --testPathPattern=\\.critical\\.test\\.js$ --no-coverage",
    "test:hooks": "jest src/hooks/__tests__ --no-coverage",
    "test:timer": "jest useTimer --no-coverage",
    "test:dial": "jest useDialOrientation --no-coverage",
    "detect:transforms": "node scripts/detect-transform-needs.js",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix",
    "lint:watch": "eslint src --ext .js,.jsx,.ts,.tsx --watch",
    "qa:visual": "expo start",
    "qa:visual:ios": "expo run:ios",
    "version:patch": "node scripts/version-bump.js patch",
    "version:minor": "node scripts/version-bump.js minor",
    "version:major": "node scripts/version-bump.js major",
    "version:set": "node scripts/version-bump.js set",
    "i18n:extract": "node scripts/i18n/01-extract-keys.js",
    "i18n:parse": "node scripts/i18n/02-parse-locales.js",
    "i18n:audit": "node scripts/i18n/01-extract-keys.js && node scripts/i18n/02-parse-locales.js && node scripts/i18n/03-audit-sync.js && node scripts/i18n/04-generate-report.js",
    "i18n:consolidate": "node scripts/i18n/05-consolidate-duplicates.js",
    "i18n:backfill": "node scripts/i18n/06-backfill-locales.js",
    "i18n:cleanup": "node scripts/i18n/07-cleanup-obsolete-keys.js",
    "i18n:validate": "npm run i18n:audit"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/jest": "29.5.14",
    "babel-preset-expo": "~55.0.8",
    "expo": "^55.0.17",
    "expo-asset": "~55.0.16",
    "expo-audio": "~55.0.14",
    "expo-dev-client": "~55.0.28",
    "expo-haptics": "~55.0.14",
    "expo-keep-awake": "~55.0.6",
    "expo-localization": "~55.0.13",
    "expo-modules-core": "~55.0.23",
    "expo-notifications": "~55.0.20",
    "expo-status-bar": "~55.0.5",
    "expo-store-review": "~55.0.13",
    "expo-updates": "~55.0.21",
    "i18n-js": "^4.5.1",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.16",
    "lucide-react-native": "^0.562.0",
    "mixpanel-react-native": "^3.1.2",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-dotenv": "^3.4.11",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-pager-view": "8.0.0",
    "react-native-purchases": "^9.5.3",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-svg": "15.15.3"
  },
  "private": true,
  "devDependencies": {
    "babel-eslint": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-plugin-jest": "^29.5.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-native": "^5.0.0",
    "glob": "^13.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "react-native-worklets": "0.7.4"
  },
  "packageManager": "yarn@4.9.1+sha512.f95ce356460e05be48d66401c1ae64ef84d163dd689964962c6888a9810865e39097a5e9de748876c2e0bf89b232d583c33982773e9903ae7a76257270986538"
}
